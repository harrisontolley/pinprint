# ─────────────────────────────────────────────────────────────────────────────
# Backend env. Secrets live in Vercel (source of truth); pull them locally with
#   vercel env pull backend/.env
# Never commit real values — only this template is committed. See
# docs/integrations/secrets.md.
# ─────────────────────────────────────────────────────────────────────────────

# Local dev port for the API (frontend proxies geocode/* + webhooks here).
PORT=8787

# Neon Postgres pooled connection string (from the Neon dashboard / integration).
# Used by /health/db, the migration runner, and order/account/rewards queries.
DATABASE_URL=

# ── Neon Auth (backend verifies session JWTs; no auth secret needed here) ──
# JWKS endpoint for the Neon Auth branch (from `provision_neon_auth`). The backend
# fetches + caches these public keys to verify the Bearer JWT on /account/* routes.
NEON_AUTH_JWKS_URL=
# Expected `iss` claim on the JWT. NOTE: this is the Neon Auth host *origin*
# (https://<branch>.neonauth.<region>.aws.neon.tech), NOT the full base_url with
# the /<db>/auth path. Optional but recommended; leave blank to skip the check.
NEON_AUTH_ISSUER=

# Guards POST /dev/orders and the seed script. Unset in prod → both 403 / no-op.
DEV_SEED_TOKEN=

# ── Admin allowlist (operator dashboard /admin + /admin/* API) ──
# Comma/space-separated emails. A signed-in user is treated as admin only when
# their verified JWT email is in this set. Unset → admin is closed (all 403).
ADMIN_EMAILS=

# ── Stripe (server-side secret — backend only, NEVER expose to the client) ──
# Test key from https://dashboard.stripe.com/test/apikeys (starts sk_test_…).
STRIPE_SECRET_KEY=
# Signing secret for the webhook endpoint. Local: printed by `stripe listen`
# (whsec_…). Prod: from the Stripe dashboard webhook you create. Used to verify
# the signature on POST /webhooks/stripe against the RAW request body.
STRIPE_WEBHOOK_SECRET=

# ── Artelo (print-on-demand fulfilment — backend only) ──
# API key from the Artelo dashboard → Integrations → Connect Integration → API.
ARTELO_API_KEY=
# API base. No separate sandbox host — test orders use the isTestOrder flag below.
ARTELO_API_BASE=https://www.artelo.io/api/open
# Signing secret for POST /webhooks/artelo, returned by POST /webhooks/save when
# you register the OrderStatusChange webhook (see /dev/artelo/register-webhook).
ARTELO_WEBHOOK_SECRET=
# When not exactly "false", every order is submitted with isTestOrder=true
# (Artelo marks it "Ignored": never produced, never charged). Set to false to go live.
ARTELO_TEST_ORDERS=true

# ── Vercel Blob (print-asset storage — backend only) ──
# Read/write token from the Vercel Blob store. The browser uploads the print-ready
# PNG via the client-upload flow; POST /uploads/token mints the short-lived token.
# NOTE: requires a provisioned Blob store. Without it, physical checkout 503s at
# the upload step (no print can be ordered). Provision: `vercel blob create-store`.
BLOB_READ_WRITE_TOKEN=
# Allowed host suffixes for print-asset URLs handed to Artelo (anti-SSRF). Defaults
# to "blob.vercel-storage.com". Override only if you serve assets from another host.
BLOB_ALLOWED_HOSTS=

# ── PostHog (optional server-side event capture; client uses NEXT_PUBLIC_* ) ──
# Project API key (phc_…). Leave unset to disable server-side capture.
POSTHOG_PROJECT_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# ── Sentry (server error tracking) ──
# DSN for the heartbound-backend Sentry project (separate from the frontend DSN).
# Server-side only — NOT NEXT_PUBLIC, never bundled to the browser. Env-guarded:
# unset = Sentry disabled (no events sent); app still builds/runs/tests. Errors-only.
SENTRY_DSN=

# ── Resend (transactional email — backend only) ──
# API key from https://resend.com/api-keys. Used to send the free lead-magnet
# poster design. Unverified accounts can send from onboarding@resend.dev, but
# only TO the account owner's own email — see docs/integrations/resend.md.
RESEND_API_KEY=
# Verified "from" address, e.g. "Heartbound Maps <hello@example.com>". Requires a
# verified sending domain in production (SPF/DKIM) — see docs/integrations/resend.md.
EMAIL_FROM=

# ── MapTiler (geocoding — backend only; powers /geocode/search + /geocode/reverse) ──
# Key from https://cloud.maptiler.com/account/keys/ (free tier). Server-side only.
# Env-guarded: unset = geocoding falls back to public Nominatim (no SLA, OSMF
# usage-policy limits). Set it to use MapTiler's managed geocoder (autocomplete,
# storage permitted). See docs/integrations/maptiler.md.
MAPTILER_API_KEY=
