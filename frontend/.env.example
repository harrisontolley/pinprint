# ─────────────────────────────────────────────────────────────────────────────
# Frontend env. ONLY NEXT_PUBLIC_* values reach the browser — never put a secret
# key here. Secrets live in Vercel; pull locally with
#   vercel env pull frontend/.env
# See docs/integrations/secrets.md.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the Heartbound Maps backend, used by the client to call /geocode/*.
# Local dev: the backend dev server. In production on Vercel "Services" this is
# injected automatically as the relative prefix "/_/backend" — leave it unset there.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8787

# ── Canonical site origin (SEO: canonical URLs, OG/Twitter images, sitemap, robots) ──
# The public production origin, no trailing slash. Used by src/lib/seo/site.ts.
# Set this to the real production domain in Vercel (Production + Preview) before
# launch — when unset, code falls back to a default origin, which would make
# canonical/sitemap URLs point at the wrong host on a custom-domain deploy.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Map picker basemap (MapLibre style for the location picker) ──
# Optional. Unset → keyless OpenFreeMap "positron" vector style (free, no SLA).
# Set to a MapTiler style URL (with ?key=…) for an SLA-backed basemap, e.g.
# https://api.maptiler.com/maps/dataviz-light/style.json?key=YOUR_KEY
# Publishable (it ships to the browser) — use a MapTiler key URL-restricted to
# your domains. See docs/integrations/maptiler.md.
NEXT_PUBLIC_MAP_STYLE_URL=

# ── Neon Auth (server-side only — NOT NEXT_PUBLIC; powers /api/auth/* + cookies) ──
# Auth base URL for the Neon Auth branch (from `provision_neon_auth`). The Next.js
# auth handler proxies /api/auth/* to it; the browser only talks to /api/auth.
NEON_AUTH_BASE_URL=
# 32+ char secret used to sign the session-data cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEON_AUTH_COOKIE_SECRET=

# ── PostHog (client analytics — publishable, safe to expose) ──
# Project API key (phc_…) from https://us.posthog.com → Project settings.
NEXT_PUBLIC_POSTHOG_KEY=
# Ingest path. We reverse-proxy through the Next app (/ingest → PostHog) so ad
# blockers don't drop events; see frontend/next.config.ts. Leave as /ingest.
NEXT_PUBLIC_POSTHOG_HOST=/ingest
# Region the proxy forwards to: https://us.i.posthog.com or https://eu.i.posthog.com.
NEXT_PUBLIC_POSTHOG_UPSTREAM=https://us.i.posthog.com

# ── Stripe (publishable key — safe to expose; used by Stripe.js at checkout) ──
# Test publishable key from https://dashboard.stripe.com/test/apikeys (pk_test_…).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Sentry (client + server error tracking) ──
# Public DSN (safe to expose) from Sentry → heartbound-frontend → Settings → Client Keys (DSN).
# Env-guarded: unset = Sentry disabled (no events sent), app still builds/runs/tests.
NEXT_PUBLIC_SENTRY_DSN=
# Build-time secret for source-map upload during `next build`. NOT NEXT_PUBLIC —
# set it in Vercel (Production/Preview), never commit it. Locally the wizard saved a
# copy to frontend/.env.sentry-build-plugin (gitignored).
SENTRY_AUTH_TOKEN=
